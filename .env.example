# ==============================================================
# WA Bridge — Environment Variables
# Copy to .env and fill in your values.
# Lines starting with # are comments.
# ==============================================================

# ------ Supabase (required) -----------------------------------
SUPABASE_URL=https://your-project.supabase.co
# Anon (public) key — used by client-side calls
SUPABASE_KEY=your-anon-key
# Service role key — used for server-side admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ Server (required) -------------------------------------
PORT=3001
# Secret token required on every API request (X-Api-Key header)
API_KEY=your-random-secret-key
# Comma-separated list of allowed CORS origins (production Vercel URL).
# Localhost (5173, 3000) is always allowed for local dev.
# If unset — falls back to https://wa-dashboard-blond.vercel.app (Omoikiri default).
ALLOWED_ORIGINS=https://wa-dashboard-blond.vercel.app

# ------ AI Worker (optional) ----------------------------------
# If set, the server-side AI worker (Claude Sonnet) runs every 30s.
# If not set, the worker is disabled — use an external scheduled task instead.
ANTHROPIC_API_KEY=

# ------ BAZA CRM module (optional) ----------------------------
# Set to "true" to mount BAZA CRM routes at /baza/api.
# Default: disabled.
ENABLE_BAZA=false

# ------ BAZA Task Engine (optional, only if ENABLE_BAZA=true) -
# Set to "true" to enable the task automation engine inside BAZA.
# Default: disabled.
BAZA_TASK_ENGINE_ENABLED=false

# ------ Telegram notifications (optional) ---------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------ Sentry error reporting (optional but recommended) -----
# DSN from sentry.io (Project Settings → Client Keys (DSN)).
# When set, all captured errors + 500s + unhandled rejections are forwarded
# to Sentry. When empty, behaviour falls back to stdout-only logging.
# Free tier: 5K events/month — sufficient for current scale.
SENTRY_DSN=

# ------ Cloudinary media uploads (optional) -------------------
CLOUDINARY_CLOUD_NAME=do0zl6hbd
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------ Cloudinary retention cleanup (optional) ---------------
# Daily cron that deletes old WhatsApp media (folder `wa-bridge/`) to keep
# the Cloudinary account under quota. PDF reports under `crm/reports` are
# never touched.
#   disabled (default) — never deletes, scheduler is silent
#   dry-run            — logs would-delete count + sample, deletes nothing
#   delete             — actually deletes
CLOUDINARY_CLEANUP_MODE=disabled
# How many days to keep media before it becomes deletable (default 90)
CLOUDINARY_RETENTION_DAYS=90
# Hour (0-23, Almaty time) when daily cleanup runs (default 04:00 — low traffic)
CLOUDINARY_CLEANUP_HOUR=4

# ------ Scheduling (optional) ---------------------------------
# Hour (0-23, server local time) when the daily AI analysis runs.
# Default: 23 (matches Almaty GMT+5 if server is UTC+0).
DAILY_ANALYSIS_HOUR=23

# ------ Branding (optional) -----------------------------------
# Company name used in AI prompts and system messages.
# Default: Omoikiri — set this in Railway env vars to match the client.
BRAND_NAME=Omoikiri
# Short lowercase identifier (no spaces) for use in technical contexts.
BRAND_SHORT=omoikiri

# ------ Business context (used in AI prompts) -----------------
# What the company sells — shown in AI analyst/classifier prompts.
# Default matches Omoikiri; override per client in their Railway env vars.
BUSINESS_DESCRIPTION=японская кухонная сантехника: мойки, смесители
# Country of operation — shown in AI prompts.
BUSINESS_COUNTRY=Kazakhstan
# Comma-separated substrings matched against WhatsApp pushName (case-insensitive).
# Chats whose display name contains any of these are tagged as "сотрудник" automatically.
EMPLOYEE_NAME_PATTERNS=OMOIKIRI,ОМОЙКИРИ,OMOIKIRI ALMATY,OMOIKIRI ASTANA

# ------ Meta Marketing API (optional) -------------------------
# When all META_* vars below are set, the meta-ads module syncs
# campaigns/insights/creatives from Facebook/Instagram Ads into
# Supabase on a 6h cron. When empty — module is dormant, no calls.
# See research/library/backend-libs/meta-marketing-api.md for setup.
#
# Facebook App credentials (developers.facebook.com → My Apps):
META_APP_ID=
META_APP_SECRET=
# System User Token (Business Manager → System Users → Generate Token).
# Use Never-Expire token with scopes: ads_read, ads_management,
# business_management. NEVER commit this to git.
META_SYSTEM_USER_TOKEN=
# Default ad account for phase 1 (single-tenant). Format: act_<digits>.
# In phase 2 (multi-tenant) tokens come from meta_ad_accounts table
# and this var becomes a fallback only.
META_AD_ACCOUNT_ID=
# Graph API version. Bump when Meta deprecates current.
# Changelog: https://developers.facebook.com/docs/graph-api/changelog/
META_API_VERSION=v22.0
# Sync interval in hours per ad_account. Min 1, default 6.
META_SYNC_INTERVAL_HOURS=6
# Set to "false" to disable the auto-sync cron entirely (default: enabled when META_SYSTEM_USER_TOKEN is set).
META_ADS_CRON_ENABLED=true

# ------ Creative Vision analysis (optional, future) ----------
# When true, uses Anthropic Vision to analyse ad creatives (image/video).
# Currently disabled — Adil reviews creatives manually. Slot kept for future.
ENABLE_CREATIVE_VISION=false
# Separate key from main ANTHROPIC_API_KEY to track vision spend separately.
ANTHROPIC_API_KEY_VISION=

# ------ Railway (auto-set by Railway, do not set manually) ----
# Used for the keep-alive self-ping URL.
# RAILWAY_PUBLIC_DOMAIN=your-service.up.railway.app
