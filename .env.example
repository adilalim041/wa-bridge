# ==============================================================
# WA Bridge — Environment Variables
# Copy to .env and fill in your values.
# Lines starting with # are comments.
# ==============================================================

# ------ Supabase (required) -----------------------------------
SUPABASE_URL=https://your-project.supabase.co
# Anon (public) key — used by client-side calls
SUPABASE_KEY=your-anon-key
# Service role key — used for server-side admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ Server (required) -------------------------------------
PORT=3001
# Secret token required on every API request (X-Api-Key header)
API_KEY=your-random-secret-key
# Comma-separated list of allowed CORS origins (production Vercel URL).
# Localhost (5173, 3000) is always allowed for local dev.
# If unset — falls back to https://wa-dashboard-blond.vercel.app (Omoikiri default).
ALLOWED_ORIGINS=https://wa-dashboard-blond.vercel.app

# ------ AI Worker (optional) ----------------------------------
# If set, the server-side AI worker (Claude Sonnet) runs every 30s.
# If not set, the worker is disabled — use an external scheduled task instead.
ANTHROPIC_API_KEY=

# ------ BAZA CRM module (optional) ----------------------------
# Set to "true" to mount BAZA CRM routes at /baza/api.
# Default: disabled.
ENABLE_BAZA=false

# ------ BAZA Task Engine (optional, only if ENABLE_BAZA=true) -
# Set to "true" to enable the task automation engine inside BAZA.
# Default: disabled.
BAZA_TASK_ENGINE_ENABLED=false

# ------ Telegram notifications (optional) ---------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------ Cloudinary media uploads (optional) -------------------
CLOUDINARY_CLOUD_NAME=do0zl6hbd
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------ Scheduling (optional) ---------------------------------
# Hour (0-23, server local time) when the daily AI analysis runs.
# Default: 23 (matches Almaty GMT+5 if server is UTC+0).
DAILY_ANALYSIS_HOUR=23

# ------ Branding (optional) -----------------------------------
# Company name used in AI prompts and system messages.
# Default: Omoikiri — set this in Railway env vars to match the client.
BRAND_NAME=Omoikiri
# Short lowercase identifier (no spaces) for use in technical contexts.
BRAND_SHORT=omoikiri

# ------ Business context (used in AI prompts) -----------------
# What the company sells — shown in AI analyst/classifier prompts.
# Default matches Omoikiri; override per client in their Railway env vars.
BUSINESS_DESCRIPTION=японская кухонная сантехника: мойки, смесители
# Country of operation — shown in AI prompts.
BUSINESS_COUNTRY=Kazakhstan
# Comma-separated substrings matched against WhatsApp pushName (case-insensitive).
# Chats whose display name contains any of these are tagged as "сотрудник" automatically.
EMPLOYEE_NAME_PATTERNS=OMOIKIRI,ОМОЙКИРИ,OMOIKIRI ALMATY,OMOIKIRI ASTANA

# ------ Railway (auto-set by Railway, do not set manually) ----
# Used for the keep-alive self-ping URL.
# RAILWAY_PUBLIC_DOMAIN=your-service.up.railway.app
